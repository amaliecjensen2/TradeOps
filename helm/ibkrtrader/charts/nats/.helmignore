# Ignorer disse filer ved `helm package`, så chart-arkivet kun indeholder det,
# Helm faktisk skal bruge ved distribution og installation.
.DS_Store

# Versionsstyringsmapper og tilhørende ignore-filer skal ikke med i et chart-arkiv.
.git/
.gitignore
.bzr/
.bzrignore
.hg/
.hgignore
.svn/

# Midlertidige backupfiler opstår lokalt under redigering og må ikke påvirke release-pakken.
*.swp
*.bak
*.tmp
*.orig
*~

# IDE-projektfiler er udviklermaskine-specifikke og skal ikke distribueres med chartet.
.project
.idea/
*.tmproj
.vscode/

# Testfiler til templates bruges under udvikling, men de skal ikke med i den publicerede chart-pakke.
/test
