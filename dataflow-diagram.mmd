%%{init: {"theme": "dark", "themeVariables": {"fontSize": "14px", "edgeLabelBackground": "#2d2d2d"}}}%%
flowchart TD
    IBKR[["IBKR Servers"]]
    OPR[["Operatřr"]]

    STR(["Strategy"])
    RG(["Risk Gateway"])
    ADP(["IBKR Adapter"])
    RM(["Risk Monitor"])
    API(["API + Dashboard"])

    NATS[("NATS JetStream")]
    TSDB[("TimescaleDB")]

    IBKR -- "kurser" --> ADP
    ADP -- "kurser" --> NATS
    NATS -- "kurser" --> STR

    STR -- "ordre" --> RG
    RG -- "godkendt" --> NATS
    NATS -- "ordre" --> ADP
    ADP -- "křb/salg" --> IBKR

    IBKR -- "handler" --> ADP
    ADP -- "handler" --> NATS

    NATS -- "handler" --> RM
    RM -. "stop!" .-> RG
    RM -. "stop!" .-> STR

    NATS --> TSDB
    NATS --> API
    TSDB --> API
    API --> OPR

    classDef external  fill:#d5e8d4,stroke:#82b366,color:#000
    classDef process   fill:#dae8fc,stroke:#6c8ebf,color:#000
    classDef datastore fill:#fff2cc,stroke:#d6b656,color:#000

    class IBKR,OPR external
    class STR,RG,ADP,RM,API process
    class NATS,TSDB datastore

    linkStyle default stroke:#ffffff,stroke-width:1.5px
